# ─────────────────────────────────────────────────────────────────
# XOXO — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────

# ── Edge API ──────────────────────────────────────────────────────
# The XOXO Cloudflare Worker URL.
# Local dev: run `cd worker && wrangler dev` → defaults to localhost:8787
# Production: edge.xoxo.ai (set after deploying the Worker)
NEXT_PUBLIC_EDGE_URL=http://localhost:8787

# ── Auth (Clerk) ──────────────────────────────────────────────────
# Sign up at clerk.com — free tier covers MVP usage.
# Dashboard: clerk.com/docs/quickstarts/nextjs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/signup

# ── Stripe (billing) ──────────────────────────────────────────────
# Sign up at stripe.com — test mode keys are safe to use for dev.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe price IDs (create these in Stripe dashboard)
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_PUBLISHER=price_REPLACE_ME

# ── Database (when you add one) ───────────────────────────────────
# Recommended: Neon (serverless Postgres, free tier, works great on Vercel)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App config ────────────────────────────────────────────────────
# Used by middleware to identify the app subdomain in production
NEXT_PUBLIC_APP_DOMAIN=app.xoxo.ai
NEXT_PUBLIC_ROOT_DOMAIN=xoxo.ai
